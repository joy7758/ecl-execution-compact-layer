{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ecl:schema:execution-compact-layer:0.1.0-draft",
  "title": "Execution Compact Layer Record",
  "description": "Deterministic local execution record that compresses state, intent, action, and evidence while preserving protocol references.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "ecl_id",
    "lineage",
    "state",
    "intent",
    "action",
    "evidence",
    "determinism",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0-draft"
    },
    "object_type": {
      "type": "string",
      "const": "ecl_execution_record"
    },
    "ecl_id": {
      "type": "string",
      "pattern": "^ecl:[A-Za-z0-9._:-]+$"
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_adapter",
        "source_trace_ref",
        "source_trace_hash",
        "generated_at",
        "checkpoint_ref"
      ],
      "properties": {
        "source_adapter": {
          "type": "string",
          "enum": [
            "openai_agents_trace",
            "langchain_trace",
            "manual_ecl"
          ]
        },
        "source_trace_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_trace_hash": {
          "$ref": "#/$defs/sha256"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "checkpoint_ref": {
          "type": "string",
          "minLength": 1
        },
        "parent_checkpoint_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_status",
        "lifecycle_phase",
        "actor_ref",
        "persona_ref",
        "runtime_ref",
        "correlation_id"
      ],
      "properties": {
        "execution_status": {
          "type": "string",
          "enum": [
            "planned",
            "running",
            "completed",
            "blocked",
            "failed",
            "partial"
          ]
        },
        "lifecycle_phase": {
          "type": "string",
          "enum": [
            "init",
            "resume",
            "execute",
            "audit",
            "complete"
          ]
        },
        "actor_ref": {
          "type": "string",
          "minLength": 1
        },
        "persona_ref": {
          "type": "string",
          "minLength": 1
        },
        "runtime_ref": {
          "type": "string",
          "minLength": 1
        },
        "correlation_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "operation",
        "constraints",
        "evidence_requirements"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "type": "string",
          "minLength": 1
        },
        "aip_intent_ref": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        },
        "expected_result": {
          "type": "object",
          "additionalProperties": true
        },
        "evidence_requirements": {
          "type": "object",
          "additionalProperties": true
        },
        "raw_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "execution_mode",
        "side_effect_class"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "execution_mode": {
          "type": "string",
          "enum": [
            "proposal",
            "direct",
            "delegated",
            "simulation",
            "unknown"
          ]
        },
        "side_effect_class": {
          "type": "string",
          "enum": [
            "read_only",
            "state_change",
            "external_write",
            "unknown"
          ]
        },
        "tool_ref": {
          "type": "string",
          "minLength": 1
        },
        "parameters_hash": {
          "$ref": "#/$defs/sha256"
        },
        "aip_action_ref": {
          "type": "string",
          "minLength": 1
        },
        "raw_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_status",
        "result_summary",
        "trace_refs",
        "event_chain",
        "policy_decisions",
        "hashes"
      ],
      "properties": {
        "result_status": {
          "type": "string",
          "enum": [
            "completed",
            "blocked",
            "failed",
            "partial",
            "unknown"
          ]
        },
        "result_summary": {
          "type": "string",
          "minLength": 1
        },
        "aip_result_ref": {
          "type": "string",
          "minLength": 1
        },
        "aro_evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "aro_receipt_ref": {
          "type": "string",
          "minLength": 1
        },
        "output_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "trace_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "event_chain": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/event"
          }
        },
        "policy_decisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/policyDecision"
          }
        },
        "hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "canonical_hash",
            "source_trace_hash"
          ],
          "properties": {
            "canonical_hash": {
              "$ref": "#/$defs/sha256"
            },
            "source_trace_hash": {
              "$ref": "#/$defs/sha256"
            },
            "event_chain_hash": {
              "$ref": "#/$defs/sha256"
            }
          }
        }
      }
    },
    "determinism": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalization",
        "hash_algorithm",
        "adapter_version",
        "generated_by"
      ],
      "properties": {
        "canonicalization": {
          "type": "string",
          "const": "json-sort-keys-no-whitespace"
        },
        "hash_algorithm": {
          "type": "string",
          "const": "sha256"
        },
        "adapter_version": {
          "type": "string",
          "minLength": 1
        },
        "generated_by": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decisions",
        "source_map",
        "validation"
      ],
      "properties": {
        "decisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/auditDecision"
          }
        },
        "source_map": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceMapEntry"
          }
        },
        "validation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validationEntry"
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "event_ref",
        "event_hash",
        "chain_hash"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "type": "string",
          "minLength": 1
        },
        "event_ref": {
          "type": "string",
          "minLength": 1
        },
        "event_hash": {
          "$ref": "#/$defs/sha256"
        },
        "chain_hash": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "policyDecision": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "decision_ref",
        "decision"
      ],
      "properties": {
        "decision_ref": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "auditDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "decision",
        "reason"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sourceMapEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ecl_path",
        "source_protocol",
        "source_path",
        "mapping_type"
      ],
      "properties": {
        "ecl_path": {
          "type": "string",
          "minLength": 1
        },
        "source_protocol": {
          "type": "string",
          "enum": [
            "POP",
            "AIP",
            "ARO",
            "ECL"
          ]
        },
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "mapping_type": {
          "type": "string",
          "enum": [
            "reference",
            "normalized_copy",
            "derived_hash",
            "local_decision"
          ]
        }
      }
    },
    "validationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator",
        "status"
      ],
      "properties": {
        "validator": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "not_run"
          ]
        },
        "report_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

